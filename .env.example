# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic API (for caption generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cloudflare R2
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_BUCKET_NAME=thechoirsource-clips
R2_PUBLIC_URL=https://your-r2-public-domain.com

# Meta (Instagram + Facebook)
META_ACCESS_TOKEN=your_meta_page_access_token_here
META_IG_USER_ID=your_instagram_user_id_here
META_PAGE_ID=your_facebook_page_id_here

# TikTok
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# Dashboard ↔ Worker shared secret
DASHBOARD_SECRET=generate_a_random_string_here

# GitHub (for Worker → Actions trigger)
GH_PAT_TOKEN=your_github_pat_here
GH_OWNER=your_github_username_here
GH_REPO=thechoirsource

# Mock mode (set to "true" to skip all external API calls)
MOCK_MODE=false
